# ============================================
# ExaContable - Configuracion de Produccion
# ============================================
# Copia este archivo como .env.production
# y completa los valores reales.
# NO subas este archivo con credenciales reales
# a repositorios publicos.
# ============================================

# --- WordPress ---
WORDPRESS_URL=https://exacontable.com
NEXT_PUBLIC_WORDPRESS_URL=https://exacontable.com

# --- URL del sitio ---
NEXT_PUBLIC_SITE_URL=https://exacontable.com

# --- Base de Datos (Prisma Postgres) ---
# Copia la URL desde Prisma Console > Connect y agrégala en Setup Node.js App.
DATABASE_URL="postgres://usuario:contrasena@host:5432/postgres?sslmode=require"

# --- Admin ---
ADMIN_EMAIL=admin@exacontable.com
ADMIN_PASSWORD_HASH=cambia_esto_con_un_hash_real_de_bcrypt

# --- JWT ---
# Genera un secreto seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=genera_un_secreto_seguro_aqui

# --- WhatsApp ---
WHATSAPP_TO=584125348402

# --- Email (SMTP) ---
# Configuracion de Nodemailer para tu proveedor de correo
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USER=tu-correo@exacontable.com
SMTP_PASS=tu-contrasena-smtp
SMTP_FROM="ExaContable <noreply@exacontable.com>"

# --- Datos bancarios (opcional) ---
NEXT_PUBLIC_BANCO_PICHINCHA_CUENTA=
NEXT_PUBLIC_BANCO_PICHINCHA_CEDULA=
NEXT_PUBLIC_BANCO_PACIFICO_CUENTA=
NEXT_PUBLIC_BANCO_PACIFICO_CEDULA=
