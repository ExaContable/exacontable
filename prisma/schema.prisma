generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Float
  category    String
  period      String
  features    String   @default("[]")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id            String   @id @default(cuid())
  orderNumber   Int      @default(0) @unique
  customerName  String
  customerEmail String
  customerPhone String?
  planId        String?
  planName      String
  total         Float
  status        String   @default("pending")
  paymentMethod String?
  paymentStatus String   @default("pending")
  receiptUrl    String?
  notes         String?

  // Custom billing and user credentials
  ruc           String?
  cedula        String?
  usuario       String?
  clave         String?
  genero        String?
  address       String?
  city          String?
  state         String?
  postcode      String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PaymentMethod {
  id              String    @id @default(cuid())
  name            String
  code            String    @unique
  description     String?
  isActive        Boolean   @default(true)
  isSandbox       Boolean   @default(true)
  config          String?
  commission      Float?
  lastValidatedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SiteConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
